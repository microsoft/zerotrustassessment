<?xml version="1.0" encoding="utf-8"?>
<packages>
  <!-- DuckDB.NET.Data.Full is the ADO.NET provider used by the module.
       DuckDB.NET.Bindings.Full carries the native DuckDB assets copied at build time. -->
  <package id="DuckDB.NET.Data.Full" version="1.4.3" targetFramework="net6.0" />
  <package id="DuckDB.NET.Bindings.Full" version="1.4.3" targetFramework="net6.0" />
</packages>
